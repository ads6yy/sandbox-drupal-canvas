{% set items = ipsosenso_menu(menu_name|default('ipsosenso_footer')) %}

<footer class="ipsosenso-footer cq-full">
  <div class="ipsosenso-footer__inner">

    <div class="ipsosenso-footer__col">
      <h4>{{ address_title|default('Nous trouver') }}</h4>
      <p>{{ address_line|default('Paris, France') }}<br>
      <a href="{{ contact_url|default('#') }}">{{ contact_label|default('Nous contacter') }}</a></p>
    </div>

    <div class="ipsosenso-footer__col">
      <h4>{{ links_title|default('Liens rapides') }}</h4>
      <p>
        {% for item in items %}
          <a href="{{ item.url }}">{{ item.title }}</a>{% if not loop.last %}<br>{% endif %}
        {% endfor %}
      </p>
    </div>

    <div class="ipsosenso-footer__col">
      <h4>{{ social_title|default('Nous suivre') }}</h4>
      <div class="ipsosenso-footer__social">
        <a href="{{ facebook_url|default('#') }}" aria-label="Facebook">
          <img src="/themes/custom/ipsosenso/assets/facebook.svg" alt="Facebook" />
        </a>
        <a href="{{ linkedin_url|default('#') }}" aria-label="LinkedIn">
          <img src="/themes/custom/ipsosenso/assets/linkedin.svg" alt="LinkedIn" />
        </a>
      </div>
    </div>

  </div>

  <div class="ipsosenso-footer__bottom">
    © {{ "now"|date("Y") }} {{ copyright|default('Démo Drupal Canvas — Tous droits réservés.') }}
  </div>
</footer>
