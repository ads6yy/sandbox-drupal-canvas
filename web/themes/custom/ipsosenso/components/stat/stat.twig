<div class="ipsosenso-stat" data-ipsosenso-stat>
  <div class="ipsosenso-stat__value flex items-baseline justify-center">
    <span class="ipsosenso-stat__number"
          data-stat-value="{{ value }}">{{ value }}</span>
    {% if suffix %}
      <span class="ipsosenso-stat__suffix">{{ suffix }}</span>
    {% endif %}
  </div>
  <div class="ipsosenso-stat__label">{{ label }}</div>
</div>
