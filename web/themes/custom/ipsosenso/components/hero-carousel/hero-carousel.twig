{% set slides = [
  { 'title': slide1_title|default('Numérique'), 'text': slide1_text|default('Accompagnement transformation digitale.') },
  { 'title': slide2_title|default('Technologique'), 'text': slide2_text|default('Experts Java, PHP, JavaScript, mobile.') },
  { 'title': slide3_title|default('Pragmatique'), 'text': slide3_text|default('Engagement forfaitaire, approche agile.') },
] %}

<section class="ipsosenso-hero relative w-full cq-full">
  {# Vidéo de fond plein écran #}
  <video class="ipsosenso-hero__video"
         autoplay muted loop playsinline>
    <source src="/themes/custom/ipsosenso/assets/header.mp4" type="video/mp4">
  </video>

  {# Overlay dégradé bleu #}
  <div class="ipsosenso-hero__overlay absolute inset-0 z-1 pointer-events-none"></div>

  {# Zone slide centrée avec overlay sombre pour la lisibilité #}
  <div class="ipsosenso-hero__slide-bg absolute inset-0 z-2 pointer-events-none"></div>

  {# Carrousel centré #}
  <div class="relative z-3 w-full h-full">
    <div class="ipsosenso-hero-carousel"
         data-ipsosenso-carousel
         data-autoplay="5000">

      <div class="ipsosenso-hero-carousel__slides relative w-full flex-1 flex items-center justify-center">
        {% for slide in slides %}
          <div class="ipsosenso-hero-carousel__slide transition-opacity duration-700 ease-in-out {{ loop.first ? 'opacity-100 relative' : 'opacity-0 absolute inset-0' }}"
               data-slide-index="{{ loop.index0 }}">
            <div class="flex flex-col items-center justify-center h-full w-full">
              <h2>{{ slide.title }}</h2>
              <p>{{ slide.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>

      {# Pagination dots #}
      <div class="ipsosenso-hero-carousel__pagination flex gap-3 mt-16 justify-center">
        {% for slide in slides %}
          <button type="button"
                  class="ipsosenso-hero-carousel__dot w-3 h-3 rounded-full transition-all border border-white {{ loop.first ? 'bg-white w-8' : 'bg-transparent' }}"
                  data-slide-target="{{ loop.index0 }}"
                  aria-label="Slide {{ loop.index }}"></button>
        {% endfor %}
      </div>
    </div>
  </div>

  {# Flèches prev/next #}
  <button type="button"
          class="ipsosenso-hero-carousel__prev absolute left-8 top-1/2 -translate-y-1/2 z-4 w-12 h-12 rounded-full border-2 border-white text-white flex items-center justify-center hover:bg-white hover:text-[#141e6e] transition-all"
          data-carousel-prev
          aria-label="Slide précédente">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 18l-6-6 6-6"/>
    </svg>
  </button>
  <button type="button"
          class="ipsosenso-hero-carousel__next absolute right-8 top-1/2 -translate-y-1/2 z-4 w-12 h-12 rounded-full border-2 border-white text-white flex items-center justify-center hover:bg-white hover:text-[#141e6e] transition-all"
          data-carousel-next
          aria-label="Slide suivante">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 18l6-6-6-6"/>
    </svg>
  </button>

  {# Indicateur scroll en bas #}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-3 text-white animate-bounce">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
    </svg>
  </div>
</section>
