{% set slides = [
  { 'title': slide1_title|default('Numérique'), 'text': slide1_text|default('Accompagnement transformation digitale.') },
  { 'title': slide2_title|default('Technologique'), 'text': slide2_text|default('Experts Java, PHP, JavaScript, mobile.') },
  { 'title': slide3_title|default('Pragmatique'), 'text': slide3_text|default('Engagement forfaitaire, approche agile.') },
] %}

<section class="ipsosenso-hero cq-full">
  <video class="ipsosenso-hero__video" autoplay muted loop playsinline>
    <source src="/themes/custom/ipsosenso/assets/header.mp4" type="video/mp4">
  </video>

  <div class="ipsosenso-hero__overlay"></div>

  <div class="ipsosenso-hero__content">
    <div class="ipsosenso-hero-carousel"
         data-ipsosenso-carousel
         data-autoplay="5000">

      <div class="ipsosenso-hero-carousel__slides">
        {% for slide in slides %}
          <div class="ipsosenso-hero-carousel__slide {{ loop.first ? 'ipsosenso-hero-carousel__slide--active' : 'ipsosenso-hero-carousel__slide--inactive' }}"
               data-slide-index="{{ loop.index0 }}">
            <h2>{{ slide.title }}</h2>
            <p>{{ slide.text }}</p>
          </div>
        {% endfor %}
      </div>

      <div class="ipsosenso-hero-carousel__pagination">
        {% for slide in slides %}
          <button type="button"
                  class="ipsosenso-hero-carousel__dot {{ loop.first ? 'ipsosenso-hero-carousel__dot--active' : '' }}"
                  data-slide-target="{{ loop.index0 }}"
                  aria-label="Slide {{ loop.index }}"></button>
        {% endfor %}
      </div>
    </div>

    <button type="button"
            class="ipsosenso-hero-carousel__prev"
            data-carousel-prev
            aria-label="Slide précédente">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>
    <button type="button"
            class="ipsosenso-hero-carousel__next"
            data-carousel-next
            aria-label="Slide suivante">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
  </div>

  <div class="ipsosenso-hero__scroll-indicator">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
    </svg>
  </div>
</section>
