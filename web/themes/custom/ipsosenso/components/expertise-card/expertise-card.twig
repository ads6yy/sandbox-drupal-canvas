{% set icons = {
  'pencil': '<path d="M3 21l3-1 11-11-3-3L3 17v4zM15.5 6.5l2 2M18 2l4 4-2 2-4-4z"/>',
  'code': '<path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>',
  'network': '<circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><path d="M12 7v4m-7 8L9 13m10 6l-4-6M8 13h8"/>',
} %}

<div class="ipsosenso-expertise-card relative bg-white rounded-lg shadow-md pt-16 pb-8 px-8 mt-12 h-full flex flex-col items-center text-center transition-transform duration-300 hover:-translate-y-2">
  {# Icône flottante au-dessus de la card #}
  <div class="ipsosenso-expertise-card__icon absolute -top-8 left-1/2 -translate-x-1/2 w-16 h-16 rounded-full bg-[#141e6e] text-white flex items-center justify-center shadow-lg">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      {{ icons[icon|default('pencil')]|raw }}
    </svg>
  </div>

  <h3 class="ipsosenso-expertise-card__title text-2xl md:text-3xl font-bold text-[#141e6e] mb-2">
    {{ title }}
  </h3>

  {% if subtitle %}
    <p class="ipsosenso-expertise-card__subtitle text-base font-semibold text-[#f08c05] mb-4 uppercase tracking-wide">
      {{ subtitle }}
    </p>
  {% endif %}

  <ul class="ipsosenso-expertise-card__list text-base text-gray-700 space-y-2 list-none p-0 w-full">
    {% for item in items|split('\n') %}
      {% set trimmed = item|trim %}
      {% if trimmed %}
        <li class="py-1 border-b border-gray-100 last:border-0">{{ trimmed }}</li>
      {% endif %}
    {% endfor %}
  </ul>
</div>
