{% set icons = {
  'pencil': '<path d="M3 21l3-1 11-11-3-3L3 17v4zM15.5 6.5l2 2M18 2l4 4-2 2-4-4z"/>',
  'code': '<path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>',
  'network': '<circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><path d="M12 7v4m-7 8L9 13m10 6l-4-6M8 13h8"/>',
} %}

<div class="ipsosenso-expertise-card">
  <div class="ipsosenso-expertise-card__icon">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      {{ icons[icon|default('pencil')]|raw }}
    </svg>
  </div>

  <h3 class="ipsosenso-expertise-card__title">{{ title }}</h3>

  {% if subtitle %}
    <div class="ipsosenso-expertise-card__subtitle">{{ subtitle }}</div>
  {% endif %}

  <ul class="ipsosenso-expertise-card__list">
    {% for item in items|split('\n') %}
      {% set trimmed = item|trim %}
      {% if trimmed %}
        <li>{{ trimmed }}</li>
      {% endif %}
    {% endfor %}
  </ul>
</div>
